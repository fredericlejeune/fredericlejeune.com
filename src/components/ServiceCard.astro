---
interface Props {
  number: string;
  title: string;
  desc: string;
  slug: string;
}
const { number, title, desc, slug } = Astro.props;
---

<a
  href={`/${slug}`}
  class="group block border border-[#e8f0f5] rounded-xl p-6 hover:border-teal hover:shadow-lg hover:shadow-teal/10 transition-all duration-200"
>
  <span class="block text-[11px] font-extrabold text-teal tracking-[2px] mb-3">{number}</span>
  <div class="w-8 h-0.5 bg-teal mb-4"></div>
  <h3 class="text-navy-deep font-extrabold text-sm mb-2">{title}</h3>
  <p class="text-muted text-[11px] font-light leading-relaxed">{desc}</p>
  <span class="block text-teal text-[10px] font-bold tracking-widest uppercase mt-4 group-hover:translate-x-1 transition-transform">
    En savoir plus →
  </span>
</a>
