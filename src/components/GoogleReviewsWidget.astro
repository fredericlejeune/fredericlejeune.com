---
/**
 * GoogleReviewsWidget
 *
 * Mode "static"  : affiche les avis de reviews.json avec le branding Google.
 * Mode "elfsight": active le widget live Elfsight dès que elfsightId est renseigné.
 *
 * Usage :
 *   <GoogleReviewsWidget />                        → statique par défaut
 *   <GoogleReviewsWidget elfsightId="xxxx-xxxx" /> → widget live Elfsight
 *
 * Pour obtenir votre elfsightId :
 *   1. Créez un compte sur https://elfsight.com/google-reviews-widget/
 *   2. Choisissez "Google Reviews"
 *   3. Connectez votre fiche Google Business Profile
 *   4. Copiez l'ID du widget (format : xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
 *   5. Passez-le dans la prop elfsightId ci-dessus
 */

import reviews from '../data/reviews.json';
import site from '../data/site.json';

interface Props {
  elfsightId?: string;           // ID Elfsight — laissez vide pour le mode statique
  googleProfileUrl?: string;     // URL profil Google Business ("Laisser un avis")
  showCount?: number;            // Nombre d'avis à afficher (mode statique, défaut : tous)
}

const {
  elfsightId = '',
  googleProfileUrl = 'https://share.google/xezwldgqIsJHQcyxm',
  showCount = reviews.length,
} = Astro.props;

const displayedReviews = reviews.slice(0, showCount);
const useElfsight = elfsightId.trim().length > 0;
---

{useElfsight ? (
  <!-- ── MODE ELFSIGHT (widget live) ── -->
  <div class="py-16 px-8 lg:px-16 bg-white">
    <div class="max-w-5xl mx-auto">
      <script src="https://static.elfsight.com/platform/platform.js" async></script>
      <div class={`elfsight-app-${elfsightId}`} data-elfsight-app-lazy></div>
    </div>
  </div>
) : (
  <!-- ── MODE STATIQUE (données JSON) ── -->
  <div class="py-16 px-8 lg:px-16 bg-white">
    <div class="max-w-5xl mx-auto">

      <!-- Bandeau Google -->
      <div class="flex flex-col sm:flex-row items-center justify-between gap-6 mb-10 pb-8 border-b border-light-bg">
        <div class="flex items-center gap-5">
          <!-- Logo Google SVG inline -->
          <svg width="92" height="32" viewBox="0 0 92 32" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Google">
            <path d="M38.16 16.36c0 4.54-3.55 7.88-7.9 7.88s-7.9-3.34-7.9-7.88c0-4.57 3.55-7.88 7.9-7.88s7.9 3.31 7.9 7.88zm-3.46 0c0-2.84-2.06-4.78-4.44-4.78s-4.44 1.94-4.44 4.78 2.06 4.78 4.44 4.78 4.44-1.96 4.44-4.78z" fill="#EA4335"/>
            <path d="M54.86 16.36c0 4.54-3.55 7.88-7.9 7.88s-7.9-3.34-7.9-7.88c0-4.57 3.55-7.88 7.9-7.88s7.9 3.31 7.9 7.88zm-3.46 0c0-2.84-2.06-4.78-4.44-4.78s-4.44 1.94-4.44 4.78 2.06 4.78 4.44 4.78 4.44-1.96 4.44-4.78z" fill="#FBBC05"/>
            <path d="M70.86 8.86v14.16c0 5.83-3.44 8.21-7.5 8.21-3.83 0-6.13-2.56-7-4.66l3.01-1.25c.54 1.28 1.85 2.8 3.99 2.8 2.61 0 4.23-1.61 4.23-4.64v-1.14h-.12c-.78.96-2.28 1.8-4.17 1.8-3.96 0-7.59-3.45-7.59-7.88 0-4.46 3.63-7.91 7.59-7.91 1.88 0 3.38.84 4.17 1.77h.12V8.86h3.27zm-3.03 7.5c0-2.78-1.85-4.81-4.21-4.81-2.39 0-4.39 2.03-4.39 4.81 0 2.75 2 4.75 4.39 4.75 2.36 0 4.21-2 4.21-4.75z" fill="#4285F4"/>
            <path d="M76.36 1.36v22.5h-3.37V1.36h3.37z" fill="#34A853"/>
            <path d="M89.16 19.32l2.69 1.79c-.87 1.28-2.96 3.49-6.58 3.49-4.49 0-7.84-3.47-7.84-7.88 0-4.69 3.38-7.88 7.45-7.88 4.1 0 6.1 3.25 6.75 5.01l.36.9-10.56 4.37c.81 1.58 2.06 2.39 3.83 2.39 1.78 0 3.01-.88 3.9-2.19zm-8.28-2.84l7.06-2.93c-.39-1-1.56-1.69-2.93-1.69-1.76 0-4.22 1.55-4.13 4.62z" fill="#EA4335"/>
            <path d="M12.36 14.02v-3.37h11.37c.11.59.17 1.28.17 2.03 0 2.52-.69 5.64-2.91 7.86-2.16 2.25-4.93 3.46-8.6 3.46C5.76 24 0 18.42 0 11.19 0 3.96 5.76-1.62 12.39-1.62c3.76 0 6.44 1.47 8.46 3.4l-2.38 2.38c-1.44-1.35-3.4-2.4-6.08-2.4C7.13 1.76 3.46 5.55 3.46 11.19c0 5.64 3.67 9.43 8.93 9.43 3.25 0 5.1-1.3 6.28-2.49.96-.96 1.59-2.34 1.84-4.11h-8.15z" fill="#4285F4"/>
          </svg>
          <div>
            <div class="flex items-center gap-2">
              <span class="text-navy-deep text-3xl font-black leading-none">{site.google.rating}</span>
              <div>
                <div class="flex text-yellow-400 text-lg leading-tight">★★★★★</div>
                <p class="text-muted text-[11px] font-light">{site.google.reviewCount} avis vérifiés</p>
              </div>
            </div>
          </div>
        </div>
        <a
          href={googleProfileUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-[#4285F4] text-white font-bold text-xs uppercase tracking-widest px-5 py-3 rounded-full hover:bg-[#3367d6] transition-colors flex items-center gap-2"
        >
          <svg width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 17h-2v-2h2v2zm2.07-7.75l-.9.92C13.45 12.9 13 13.5 13 15h-2v-.5c0-1.1.45-2.1 1.17-2.83l1.24-1.26c.37-.36.59-.86.59-1.41 0-1.1-.9-2-2-2s-2 .9-2 2H8c0-2.21 1.79-4 4-4s4 1.79 4 4c0 .88-.36 1.68-.93 2.25z"/></svg>
          Laisser un avis
        </a>
      </div>

      <!-- Grille des avis -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        {displayedReviews.map((r) => (
          <div class="bg-light-bg rounded-2xl p-5 flex flex-col gap-3 hover:shadow-md transition-shadow">
            <!-- Header carte -->
            <div class="flex items-start justify-between">
              <div class="flex items-center gap-3">
                <div class="w-9 h-9 rounded-full bg-navy-mid flex items-center justify-center flex-shrink-0">
                  <span class="text-white text-sm font-black">{r.author.charAt(0)}</span>
                </div>
                <div>
                  <p class="text-navy-deep text-sm font-bold leading-tight">{r.author}</p>
                  <p class="text-muted text-[10px] font-light">{r.location}</p>
                </div>
              </div>
              <!-- Google G icon -->
              <svg width="18" height="18" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" class="flex-shrink-0 mt-0.5">
                <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
                <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
                <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
                <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
              </svg>
            </div>

            <!-- Étoiles -->
            <div class="flex text-yellow-400 text-sm leading-none">
              {'★'.repeat(r.rating)}
            </div>

            <!-- Texte -->
            <p class="text-muted text-[12px] font-light leading-relaxed flex-1">« {r.text} »</p>
          </div>
        ))}
      </div>

      <!-- Voir tous les avis -->
      <div class="mt-8 text-center">
        <a
          href={googleProfileUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-[#4285F4] text-sm font-semibold hover:underline"
        >
          Voir les {site.google.reviewCount} avis sur Google Maps →
        </a>
      </div>
    </div>
  </div>
)}
