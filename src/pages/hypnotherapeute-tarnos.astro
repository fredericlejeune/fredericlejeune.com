---
import BaseLayout from '../layouts/BaseLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import services from '../data/services.json';
import site from '../data/site.json';
---

<BaseLayout
  title="Hypnothérapeute à Tarnos – Frédéric Lejeune | Cabinet 40220"
  description="Frédéric Lejeune, hypnothérapeute à Tarnos (40220). Séances personnalisées pour le tabac, l'anxiété, les phobies. 140 avis 4,9/5. Prenez RDV en ligne."
>
  <section class="bg-gradient-to-br from-navy-deep to-navy py-16 px-8 lg:px-16">
    <div class="max-w-4xl mx-auto">
      <p class="text-teal text-[10px] font-bold tracking-[3px] uppercase mb-4">Pays Basque · Landes</p>
      <h1 class="text-white text-4xl lg:text-5xl font-black leading-tight mb-4">
        Hypnothérapeute à Tarnos (40220)
      </h1>
      <p class="text-white/60 text-sm font-light leading-relaxed max-w-2xl mb-8">
        Cabinet situé au 24 Boulevard Jacques Duclos à Tarnos, à 5 minutes de Bayonne et Biarritz. Consultations du lundi au vendredi, créneaux le soir disponibles.
      </p>
      <a href="/rendez-vous" class="bg-teal text-navy-deep font-extrabold text-[11px] uppercase tracking-widest px-7 py-4 rounded-full inline-block hover:bg-teal/90 transition-colors">
        Prendre rendez-vous →
      </a>
    </div>
  </section>

  <section class="py-16 px-8 lg:px-16 bg-white">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-navy-deep text-2xl font-black mb-4">Cabinet d'hypnothérapie à Tarnos</h2>
      <p class="text-muted text-sm font-light leading-relaxed mb-6">
        Le cabinet de Frédéric Lejeune est situé à Tarnos, dans les Landes, à quelques minutes de Bayonne et Biarritz. Il accueille des patients de toute la région : Tarnos, Bayonne, Anglet, Biarritz, Saint-Jean-de-Luz, Hendaye, et les communes des Landes environnantes.
      </p>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm text-muted font-light">
        <div class="bg-light-bg p-5 rounded-xl">
          <p class="font-bold text-navy-deep mb-1">Adresse</p>
          <p>{site.address.street}<br />{site.address.postalCode} {site.address.city}</p>
        </div>
        <div class="bg-light-bg p-5 rounded-xl">
          <p class="font-bold text-navy-deep mb-1">Contact</p>
          <p>{site.phoneDisplay}<br />{site.email}</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-16 px-8 lg:px-16 bg-light-bg">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-navy-deep text-2xl font-black mb-10">Domaines d'intervention à Tarnos</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {services.slice(0, 6).map(s => (
          <ServiceCard number={s.number} title={s.title} desc={s.shortDesc} slug={s.slug} />
        ))}
      </div>
    </div>
  </section>

  <section class="bg-teal py-16 px-8 text-center">
    <h2 class="text-navy-deep text-3xl font-black mb-3">Rendez-vous découverte à Tarnos</h2>
    <p class="text-navy-deep/60 text-sm font-light mb-8">L'hypnose est-elle faite pour vous ?</p>
    <a href="/rendez-vous" class="bg-navy-deep text-white font-extrabold text-sm uppercase tracking-widest px-10 py-5 rounded-full inline-block hover:bg-navy transition-colors">
      Réserver ma séance
    </a>
  </section>
</BaseLayout>
