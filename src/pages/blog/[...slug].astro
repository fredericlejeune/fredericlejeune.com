---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: post,
  }));
}

const post = Astro.props;
const { Content } = await render(post);
---

<BaseLayout title={post.data.title} description={post.data.description}>
  <section class="bg-gradient-to-br from-navy-deep to-navy py-16 px-8 lg:px-16">
    <div class="max-w-3xl mx-auto">
      <nav class="text-[10px] text-white/40 font-semibold uppercase tracking-widest mb-6">
        <a href="/" class="hover:text-teal transition-colors">Accueil</a>
        <span class="mx-2">›</span>
        <a href="/blog" class="hover:text-teal transition-colors">Blog</a>
      </nav>
      <h1 class="text-white text-3xl lg:text-4xl font-black leading-tight">{post.data.title}</h1>
    </div>
  </section>

  <article class="py-16 px-8 lg:px-16 max-w-3xl mx-auto prose prose-headings:font-black prose-headings:text-navy-deep prose-p:text-muted prose-p:font-light prose-p:leading-relaxed prose-a:text-teal prose-li:text-muted prose-li:font-light">
    <Content />
  </article>

  <section class="bg-teal py-16 px-8 text-center">
    <h2 class="text-navy-deep text-3xl font-black mb-3">Rendez-vous découverte</h2>
    <p class="text-navy-deep/60 text-sm font-light mb-8">L'hypnose est-elle faite pour vous ?</p>
    <a href="/rendez-vous" class="bg-navy-deep text-white font-extrabold text-sm uppercase tracking-widest px-10 py-5 rounded-full inline-block hover:bg-navy transition-colors">
      Réserver ma séance
    </a>
  </section>
</BaseLayout>
