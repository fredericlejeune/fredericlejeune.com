---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout
  title="Blog Hypnose – Conseils & informations | Frédéric Lejeune"
  description="Découvrez les articles de Frédéric Lejeune sur l'hypnose : comment se déroule une séance, hypnose vs psychologue, arrêt du tabac, gestion du stress et plus."
>
  <section class="bg-gradient-to-br from-navy-deep to-navy py-16 px-8 lg:px-16">
    <div class="max-w-4xl mx-auto">
      <p class="text-teal text-[10px] font-bold tracking-[3px] uppercase mb-3">Ressources</p>
      <h1 class="text-white text-4xl font-black mb-3">Blog & Ressources</h1>
      <p class="text-white/60 text-sm font-light">Tout ce que vous devez savoir sur l'hypnose thérapeutique</p>
    </div>
  </section>

  <section class="py-16 px-8 lg:px-16 bg-white">
    <div class="max-w-4xl mx-auto grid gap-6">
      {posts.map(post => (
        <a href={`/blog/${post.id}`} class="group block border border-[#e8f0f5] rounded-xl p-6 hover:border-teal hover:shadow-lg hover:shadow-teal/10 transition-all">
          <h2 class="text-navy-deep font-extrabold text-lg mb-2 group-hover:text-teal transition-colors">{post.data.title}</h2>
          <p class="text-muted text-sm font-light leading-relaxed mb-4">{post.data.description}</p>
          <span class="text-teal text-[11px] font-bold uppercase tracking-widest">Lire l'article →</span>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
